# Email Configuration for Contact Form
# Copy this file to .env.local and fill in your actual values

# Resend Email Service Configuration
# 1. Sign up for free at https://resend.com
# 2. Go to API Keys in your dashboard
# 3. Create a new API key
# 4. Copy the API key and paste it below

RESEND_API_KEY=re_your_api_key_here

# Inbox where the contact form sends mail (optional; defaults to data/site.ts)
CONTACT_EMAIL=lucaslisboalves@hotmail.com

# Note: Resend has a free tier with 3,000 emails/month
# The "from" email will be "onboarding@resend.dev" initially
# To use your own domain, verify it in Resend dashboard and update the "from" field in route.ts
